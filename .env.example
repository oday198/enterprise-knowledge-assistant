APP_NAME=Enterprise Knowledge Assistant
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

METADATA_DB_URL=sqlite:///./data/app.db
CHUNK_SIZE=220
CHUNK_OVERLAP=40
DEFAULT_TOP_K=5
MAX_TOP_K=10