APP_NAME=Enterprise Knowledge Assistant
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

BACKEND_CORS_ORIGINS=http://your-ec2-public-ip,http://your-domain.com

OPENAI_API_KEY=your_openai_api_key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

CHUNK_SIZE=220
CHUNK_OVERLAP=40
DEFAULT_TOP_K=5
MAX_TOP_K=10

METADATA_DB_URL=sqlite:///./data/app.db